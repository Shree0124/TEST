{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/wlb/**",
        "destination": "https://wlbapi.toolforge.org/api/wlb/"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
